PORT=4000

# Base de datos MySQL
DB_HOST=db
DB_PORT=3306
DB_USER=appuser
DB_PASSWORD=apppass
DB_NAME=suscrip_manager

# Clave de encriptación de credenciales (base64, 32 bytes)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRED_ENC_KEY_B64=REEMPLAZA_CON_TU_CLAVE

# Email (Gmail SMTP)
# Requiere 2FA activado en Google + App Password en:
# https://myaccount.google.com/apppasswords
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Horario del reporte diario (cron, UTC)
# Guatemala = UTC-6, 8:00 AM GT = 14:00 UTC
DAILY_REPORT_CRON=0 14 * * *
